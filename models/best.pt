from ultralytics import YOLO
import os

def train_custom_model():
    # 1. Khởi tạo mô hình nền (Pre-trained model)
    # Chúng ta dùng bản 'nano' (yolov8n) để nhẹ, phù hợp chạy Web/Streamlit
    model = YOLO('yolov8n.pt') 

    # 2. Cấu hình các tham số huấn luyện
    # data: đường dẫn tới file data.yaml (Thành viên 1 cung cấp)
    # epochs: số lần học lại toàn bộ tập dữ liệu (thường từ 50-100)
    # imgsz: kích thước ảnh đầu vào (640 là tiêu chuẩn của YOLO)
    # device: '0' nếu có GPU (Nvidia), 'cpu' nếu không có card đồ họa
    results = model.train(
        data='dataset/data.yaml', 
        epochs=100, 
        imgsz=640, 
        batch=16,
        name='car_logo_model',
        device='0' 
    )

    print("Huấn luyện hoàn tất!")
    print(f"File trọng số tốt nhất được lưu tại: {results.save_dir}/weights/best.pt")

if __name__ == "__main__":
    train_custom_model()
