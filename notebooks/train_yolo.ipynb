from ultralytics import YOLO

# 3. Khởi tạo và huấn luyện
def start_training():
    model = YOLO('yolov8n.pt') # Tải mô hình gốc của Google/Ultralytics
    
    # Huấn luyện mô hình với file data.yaml
    model.train(
        data='/content/dataset/data.yaml', 
        epochs=20,     # Chạy thử 20 lần để xem có lỗi không
        imgsz=640, 
        device='cpu'   # Nếu Colab có GPU thì đổi thành device=0
    )
    print("--- HUẤN LUYỆN XONG! ---")

if __name__ == "__main__":
    start_training()
